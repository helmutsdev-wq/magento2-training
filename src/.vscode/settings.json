{
  "xml.validation.noGrammar": "ignore",
  "intelephense.files.maxSize": 20000000,
  "intelephense.files.exclude": [
    "**/.git/**",
    "**/pub/media/**",
    "**/pub/static/**",
    "**/dev/**",
    "**/var/**",
    "**/lib/**",
    "**/generated/metadata/**",
    "**/Interceptor.php",
    "**/Proxy.php",
    "**/vendor/magento/magento2-base/dev/**",
    "**/vendor/rector/**",
    "**/vendor/phpunit/**",
    "**/vendor/squizlabs/**",
    "**/vendor/phpspec/**",
    "**/vendor/behat/**",
    "**/vendor/sebastian/**",
    "**/vendor/giggsey/**",
    "**/vendor/aws/**"
  ],
  "intelephense.environment.phpVersion": "8.4.0",
  "editor.rulers": [120],
  "editor.wordWrap": "bounded",
  "editor.wordWrapColumn": 120,
}
